# UBI Bot — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# Telegram bot token — get one from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID — used for hidden admin commands (/reboot, etc.)
# To find your ID: message @userinfobot on Telegram
ADMIN_TELEGRAM_ID=your_telegram_user_id_here

# Local node domain — the user-facing domain for THIS UBI node.
# Used by federation to render handles from other nodes as `slot:slot:slot@<domain>`
# and to populate users.node_domain at registration. Optional; defaults to
# "localhost" if unset. The live production node uses "cat.ubi.asia".
# Federation transport (HTTP+JSON+Ed25519 vs. Avalanche, etc.) is not decided
# yet — this value is architecture-agnostic.
LOCAL_NODE_DOMAIN=localhost

# Federation — stage 2a (Ed25519 identity + WebFinger-style discovery).
# All three of these are optional with sensible defaults.

# Directory where the per-node Ed25519 keypair is persisted. Defaults
# to ~/.ubi-bot/. The bot creates this dir mode 700 on first boot,
# writes node_private_key.pem (mode 600) and node_public_key.pem (mode
# 644). NEVER share the private key file; treat it like BOT_TOKEN.
NODE_KEY_DIR=~/.ubi-bot

# Port for the federation HTTP server (serves /.well-known/ubi-node
# and, in stage 2b, the signed transfer endpoints). Defaults to 8765.
# Route your public 443 to this port via Caddy / nginx / panel proxy.
FEDERATION_HTTP_PORT=8765

# Bind address for the federation HTTP server. Default 0.0.0.0 makes
# it reachable from any interface. Set to 127.0.0.1 when running
# behind a reverse proxy on the same host to lock to loopback.
FEDERATION_HTTP_HOST=0.0.0.0
